// MULTI-TENANCY & IDENTITY

model Tenant {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  slug     String  @unique
  plan     String  @default("standard")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  users             User[]
  roles             Role[]
  userRoles         UserRole[]
  billboards        Billboard[]
  orders            Order[]
  contractTemplates ContractTemplate[]
  platformFeeRules  PlatformFeeRule[]

  @@map("tenants")
}

model User {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String?      @default("a2b77063-b881-426f-bf12-8d1018650450") @map("tenant_id") @db.Uuid // I set default id after creating one record in the tenants table
  email             String       @db.Citext
  phone             String?
  passwordHash      String       @map("password_hash")
  fullName          String       @map("full_name")
  businessName      String       @map("business_name")
  businessUrl       String?      @map("business_url")
  avatarUrl         String?      @map("avatar_url")
  primaryRole       UserRoleCode @default(advertiser) @map("primary_role")
  status            UserStatus   @default(pending_verification)
  defaultCityId     String?      @map("default_city_id") @db.Uuid
  defaultLat        Float?       @map("default_lat")
  defaultLng        Float?       @map("default_lng")
  preferredCurrency String       @default("INR") @map("preferred_currency") @db.Char(3)
  emailVerifiedAt   DateTime?    @map("email_verified_at") @db.Timestamptz
  phoneVerifiedAt   DateTime?    @map("phone_verified_at") @db.Timestamptz
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @default(now()) @map("updated_at") @db.Timestamptz

  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  defaultCity City?   @relation(fields: [defaultCityId], references: [id])

  userRoles                     UserRole[]
  ownedBillboards               Billboard[]               @relation("BillboardOwner")
  ordersPlaced                  Order[]
  bookingItemsOwned             BookingItem[]             @relation("BookingItemOwner")
  reviewsWritten                Review[]
  artworkUploads                ArtworkUpload[]
  paymentMethods                PaymentMethod[]
  payouts                       Payout[]
  notifications                 Notification[]
  auditLogEntries               AuditLog[]                @relation("AuditActor")
  contractAcceptances           OrderContractAcceptance[]
  verificationDocumentsOwned    VerificationDocument[]    @relation("VerificationDocumentOwner")
  verificationDocumentsReviewed VerificationDocument[]    @relation("VerificationDocumentReviewer")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Role {
  id       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String?      @map("tenant_id") @db.Uuid
  code     UserRoleCode
  name     String

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@map("roles")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}
