// 2. LOCATION & GEOGRAPHY

model City {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  stateRegion String? @map("state_region")
  countryCode String  @map("country_code") @db.Char(2)
  timezone    String

  // PostGIS geography column — not directly writable/queryable through Prisma Client.
  // Use $queryRaw / $executeRaw for spatial operations (see post_migration.sql notes).
  centroid Unsupported("geography(Point, 4326)")?

  users     User[]
  addresses Address[]

  @@unique([name, stateRegion, countryCode])
  @@map("cities")
}

model Address {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  line1        String
  line2        String?
  neighborhood String?
  cityId       String  @map("city_id") @db.Uuid
  postalCode   String? @map("postal_code")
  lat          Float
  lng          Float

  // GENERATED ALWAYS AS (ST_SetSRID(ST_MakePoint(lng, lat), 4326)::geography) STORED
  // Created by post_migration.sql — read-only, not writable via Prisma Client.
  geo Unsupported("geography(Point, 4326)")?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  city       City        @relation(fields: [cityId], references: [id])
  billboards Billboard[]

  @@index([cityId])
  @@map("addresses")
}
